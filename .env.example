# Your Re:lation tenant subdomain. The URL you use in the browser is:
#   https://<RELATION_SUBDOMAIN>.relationapp.jp
RELATION_SUBDOMAIN=yourtenant

# Default message_box_id (受信箱 ID). You can find it in the URL after logging in:
#   https://<subdomain>.relationapp.jp/tickets/#/<MESSAGE_BOX_ID>/...
# You can still pass a different message_box_id per tool call if you need to.
RELATION_MESSAGE_BOX_ID=1

# Access token. Issue one from Re:lation admin UI (API token section).
# Treat it like a password — never commit, never share.
RELATION_ACCESS_TOKEN=your_access_token_here
