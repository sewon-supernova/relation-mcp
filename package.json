{
  "name": "relation-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Re:lation (ingage.jp) — ticket, customer, and mail operations from Claude / any MCP client.",
  "license": "MIT",
  "author": "Sewon Kim <sewon@supernova-tokyo.jp>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sewon-supernova/relation-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/sewon-supernova/relation-mcp/issues"
  },
  "homepage": "https://github.com/sewon-supernova/relation-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "relation",
    "relationapp",
    "ingage",
    "customer-support",
    "claude"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "relation-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
